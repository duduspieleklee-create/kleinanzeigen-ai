{
  "family": "kleinanzeigen-worker",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::__AWS_ACCOUNT_ID__:role/kleinanzeigen-ecs-execution-role",
  "containerDefinitions": [
    {
      "name": "worker",
      "image": "__AWS_ACCOUNT_ID__.dkr.ecr.__AWS_REGION__.amazonaws.com/kleinanzeigen-ai-worker:latest",
      "essential": true,
      "environment": [{ "name": "ENVIRONMENT", "value": "production" }],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "kleinanzeigen/DATABASE_URL" },
        { "name": "REDIS_URL", "valueFrom": "kleinanzeigen/REDIS_URL" },
        { "name": "SECRET_KEY", "valueFrom": "kleinanzeigen/SECRET_KEY" },
        { "name": "APP_PASSWORD", "valueFrom": "kleinanzeigen/APP_PASSWORD" },
        { "name": "SYSTEM_USER_ID", "valueFrom": "kleinanzeigen/SYSTEM_USER_ID" },
        { "name": "VAPID_PRIVATE_KEY", "valueFrom": "kleinanzeigen/VAPID_PRIVATE_KEY" },
        { "name": "VAPID_PUBLIC_KEY", "valueFrom": "kleinanzeigen/VAPID_PUBLIC_KEY" },
        { "name": "VAPID_EMAIL", "valueFrom": "kleinanzeigen/VAPID_EMAIL" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/kleinanzeigen-worker",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "worker"
        }
      }
    }
  ]
}
