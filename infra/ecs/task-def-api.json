{
  "family": "kleinanzeigen-api",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::__AWS_ACCOUNT_ID__:role/kleinanzeigen-ecs-execution-role",
  "containerDefinitions": [
    {
      "name": "api",
      "image": "__AWS_ACCOUNT_ID__.dkr.ecr.__AWS_REGION__.amazonaws.com/kleinanzeigen-ai-api:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8000, "protocol": "tcp" }],
      "environment": [{ "name": "ENVIRONMENT", "value": "production" }],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "kleinanzeigen/DATABASE_URL" },
        { "name": "REDIS_URL", "valueFrom": "kleinanzeigen/REDIS_URL" },
        { "name": "SECRET_KEY", "valueFrom": "kleinanzeigen/SECRET_KEY" },
        { "name": "APP_USERNAME", "valueFrom": "kleinanzeigen/APP_USERNAME" },
        { "name": "APP_PASSWORD", "valueFrom": "kleinanzeigen/APP_PASSWORD" },
        { "name": "ALLOWED_EMAILS", "valueFrom": "kleinanzeigen/ALLOWED_EMAILS" },
        { "name": "ADMIN_EMAILS", "valueFrom": "kleinanzeigen/ADMIN_EMAILS" },
        { "name": "SYSTEM_USER_ID", "valueFrom": "kleinanzeigen/SYSTEM_USER_ID" },
        { "name": "VAPID_PRIVATE_KEY", "valueFrom": "kleinanzeigen/VAPID_PRIVATE_KEY" },
        { "name": "VAPID_PUBLIC_KEY", "valueFrom": "kleinanzeigen/VAPID_PUBLIC_KEY" },
        { "name": "VAPID_EMAIL", "valueFrom": "kleinanzeigen/VAPID_EMAIL" },
        { "name": "GOOGLE_CLIENT_ID", "valueFrom": "kleinanzeigen/GOOGLE_CLIENT_ID" },
        { "name": "GOOGLE_CLIENT_SECRET", "valueFrom": "kleinanzeigen/GOOGLE_CLIENT_SECRET" },
        { "name": "STRIPE_SECRET_KEY", "valueFrom": "kleinanzeigen/STRIPE_SECRET_KEY" },
        { "name": "STRIPE_WEBHOOK_SECRET", "valueFrom": "kleinanzeigen/STRIPE_WEBHOOK_SECRET" },
        { "name": "STRIPE_PRICE_CORE", "valueFrom": "kleinanzeigen/STRIPE_PRICE_CORE" },
        { "name": "STRIPE_PRICE_PRO", "valueFrom": "kleinanzeigen/STRIPE_PRICE_PRO" },
        { "name": "PUBLIC_BASE_URL", "valueFrom": "kleinanzeigen/PUBLIC_BASE_URL" },
        { "name": "RESEND_API_KEY", "valueFrom": "kleinanzeigen/RESEND_API_KEY" },
        { "name": "EMAIL_FROM", "valueFrom": "kleinanzeigen/EMAIL_FROM" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/kleinanzeigen-api",
          "awslogs-region": "__AWS_REGION__",
          "awslogs-stream-prefix": "api"
        }
      }
    }
  ]
}
