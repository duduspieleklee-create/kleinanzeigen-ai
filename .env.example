# ==========================================
# Environment Variables for kleinanzeigen-ai
# Copy this file to .env and fill in values
# ==========================================

# ── Core (required) ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://kleinanzeigen:secret@db:5432/kleinanzeigen_ai
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-in-production

# ── Postgres credentials (used by docker-compose.prod.yml's db service) ───────
# Must match the credentials embedded in DATABASE_URL above.
POSTGRES_USER=kleinanzeigen
POSTGRES_PASSWORD=secret
POSTGRES_DB=kleinanzeigen_ai

# ── Google OAuth (required for login) ─────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI (dev):  http://localhost:8000/auth/google/callback
# Authorised redirect URI (prod): https://<your-domain>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Bootstrap admin login (optional) ──────────────────────────────────────────
# A username/password fallback on the login form, only for creating the very
# first admin account before any Google-OAuth admin exists (see ADMIN_EMAILS
# below). It's a single shared credential with no per-person audit trail —
# once you have a real admin signed in via Google, set this to false.
BOOTSTRAP_ADMIN_ENABLED=true
APP_USERNAME=admin
# Required (>=12 chars) outside ENVIRONMENT=dev, or the app refuses to start.
APP_PASSWORD=change-me-in-production

# ── Email sending via SendGrid HTTP API (optional) ────────────────────────────
# Create an API key at https://app.sendgrid.com/settings/api_keys
# (scoped to "Mail Send"). Leave empty to disable email sending — in dev
# password signups are then auto-verified for convenience.
SENDGRID_API_KEY=
EMAIL_FROM=noreply@example.com

# ── App behaviour (optional) ──────────────────────────────────────────────────
ENVIRONMENT=dev
# Comma-separated allow-list of Google email addresses; empty = allow all accounts
ALLOWED_EMAILS=
# Comma-separated Google email addresses auto-promoted to admin on login;
# empty = auto-promote no one (use BOOTSTRAP_ADMIN_ENABLED above instead)
ADMIN_EMAILS=

# ── Celery Beat scheduled search (optional) ───────────────────────────────────
# User ID that owns Beat-created scrape tasks; must match an existing DB row
SYSTEM_USER_ID=1
BEAT_KEYWORDS=handwerker
BEAT_LOCATION=berlin
BEAT_PRICE_MAX=200

# ── Web Push notifications (optional) ─────────────────────────────────────────
# Generate keys (raw base64url format — NOT PEM, see app/worker/tasks.py):
# python3 -c "
# import base64
# from py_vapid import Vapid
# from cryptography.hazmat.primitives.serialization import Encoding, PublicFormat
# v = Vapid(); v.generate_keys()
# priv = v.private_key.private_numbers().private_value.to_bytes(32, 'big')
# pub = v.private_key.public_key().public_bytes(Encoding.X962, PublicFormat.UncompressedPoint)
# print('VAPID_PRIVATE_KEY=' + base64.urlsafe_b64encode(priv).decode().rstrip('='))
# print('VAPID_PUBLIC_KEY=' + base64.urlsafe_b64encode(pub).decode().rstrip('='))
# "
# Leave empty to disable push notifications
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_EMAIL=mailto:admin@example.com

# ── Stripe billing (optional — leave empty to disable paid plans) ─────────────
# Secret key: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook signing secret for POST /billing/webhook
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs (price_...) for the Core and Pro plans
STRIPE_PRICE_CORE=
STRIPE_PRICE_PRO=
# Public origin for Stripe redirects, e.g. https://your-domain.example
PUBLIC_BASE_URL=

# ── Cloudflare Turnstile (optional — bot protection on login/register) ────────
# Create a widget at https://dash.cloudflare.com/ → Turnstile → Add site.
# The site key is public (rendered into the form); the secret key validates
# the token server-side via the siteverify API — keep it secret. Leave BOTH
# empty to disable Turnstile (the public forms then submit without a challenge).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Error tracking (Sentry, optional) ─────────────────────────────────────────
# DSN from https://sentry.io/ → Settings → Projects → <project> → Client Keys.
# Leave empty to disable.
SENTRY_DSN=

# ── Custom model endpoint (optional — OpenAI-compatible) ────────────────────
# Lets Smart Search Suggestions query any OpenAI-compatible Chat Completions API
# (OpenAI, vLLM, Ollama, llama.cpp, Together, …) for context-aware suggestions.
# EINFACHST: nur CUSTOM_MODEL_PROVIDER + CUSTOM_MODEL_NAME setzen:
#   ollama   → http://localhost:11434/v1            (kein Key nötig)
#   openai   → https://api.openai.com/v1            (CUSTOM_MODEL_API_KEY nötig)
#   together → https://api.together.xyz/v1          (CUSTOM_MODEL_API_KEY nötig)
# ODER explizit: CUSTOM_MODEL_ENDPOINT + CUSTOM_MODEL_NAME (überschreibt Preset).
CUSTOM_MODEL_PROVIDER=
CUSTOM_MODEL_ENDPOINT=
CUSTOM_MODEL_API_KEY=
CUSTOM_MODEL_NAME=
CUSTOM_MODEL_TEMPERATURE=0.3
CUSTOM_MODEL_MAX_TOKENS=128
