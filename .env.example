# ============================================
# Environment Variables for kleinanzeigen-ai
# Copy this file to .env and update the values
# ============================================

# Database (used by API and Worker)
DATABASE_URL=postgresql://kleinanzeigen:secret@db:5432/kleinanzeigen_ai

# Redis (used by Celery)
REDIS_URL=redis://redis:6379/0

# JWT Secret Key (used for authentication)
SECRET_KEY=supersecretkey123-change-this-in-production

# ============================================
# Optional / Future Use
# ============================================

# Google OAuth (for later)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Azure Key Vault (when running on AKS)
# AZURE_KEY_VAULT_NAME=kleinanzeigen-kv-dev
